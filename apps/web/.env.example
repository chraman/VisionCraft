# Frontend (apps/web) — Vite Environment Variables
# All variables must be prefixed with VITE_ to be exposed to the browser
# Copy to .env.local

# API Gateway base URL
VITE_API_BASE_URL=http://localhost:3000

# LaunchDarkly client-side key (from LaunchDarkly dashboard)
VITE_LAUNCHDARKLY_CLIENT_KEY=<your-launchdarkly-client-key>

# Sentry DSN for error tracking (browser SDK)
VITE_SENTRY_DSN=<your-sentry-dsn>

# PostHog for analytics (browser SDK)
VITE_POSTHOG_KEY=<your-posthog-key>
VITE_POSTHOG_HOST=https://app.posthog.com
