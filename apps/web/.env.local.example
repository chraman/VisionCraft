# Local development — copy to .env.local (gitignored) and fill in values
# Loaded when running: pnpm dev  OR  pnpm build (--mode local)

VITE_APP_ENV=local
VITE_API_BASE_URL=http://localhost:3000

VITE_LAUNCHDARKLY_CLIENT_KEY=<your-launchdarkly-dev-client-key>
VITE_SENTRY_DSN=<your-sentry-dsn>
VITE_POSTHOG_KEY=<your-posthog-key>
VITE_POSTHOG_HOST=https://app.posthog.com
