# Production environment — template for vite build --mode prod
# In CI: secret values are injected as environment variables.
# Never commit real values.

VITE_APP_ENV=prod
VITE_API_BASE_URL=https://api.visioncraft.io

VITE_LAUNCHDARKLY_CLIENT_KEY=<your-launchdarkly-prod-client-key>
VITE_SENTRY_DSN=<your-prod-sentry-dsn>
VITE_POSTHOG_KEY=<your-posthog-key>
VITE_POSTHOG_HOST=https://app.posthog.com
