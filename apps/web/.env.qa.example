# QA environment — template for vite build --mode qa
# In CI: secret values (VITE_LAUNCHDARKLY_CLIENT_KEY etc.) are injected as
# environment variables which override this file — no .env.qa is committed.
# For local testing against QA: copy to .env.qa.local and fill in real values.

VITE_APP_ENV=qa
VITE_API_BASE_URL=https://<qa-alb-dns>

VITE_LAUNCHDARKLY_CLIENT_KEY=<your-launchdarkly-qa-client-key>
VITE_SENTRY_DSN=<your-qa-sentry-dsn>
VITE_POSTHOG_KEY=<your-posthog-key>
VITE_POSTHOG_HOST=https://app.posthog.com
