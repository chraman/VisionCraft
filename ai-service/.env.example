# AI Service (FastAPI Python) — Environment Variables
# Copy to .env and fill in real values

PORT=8000
SERVICE_NAME=ai-service

# ─── Provider Priority ────────────────────────────────────────────────────────
# Comma-separated list. Only providers with their key/URL set are active.
# First available provider in the list is tried first; falls back on error.
#
# Options: local, stability, openai, gemini, huggingface
PROVIDER_PRIORITY=stability,openai,gemini,huggingface

# ─── Local Model (Kaggle / local GPU) ────────────────────────────────────────
# Expose a local model via ngrok and set the URL here.
# See ai-service/kaggle_server.py for the server script to run on Kaggle.
# To use: set PROVIDER_PRIORITY=local (or local,openai for fallback)
LOCAL_MODEL_URL=

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Stability AI — https://platform.stability.ai
STABILITY_API_KEY=

# OpenAI (DALL-E 3) — https://platform.openai.com
OPENAI_API_KEY=

# Google Imagen 3 — https://aistudio.google.com (free tier available)
GEMINI_API_KEY=

# HuggingFace Inference API — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ─── Safety Middleware ────────────────────────────────────────────────────────
# Set to true when ai.safety_check.enabled feature flag is ON (Phase 3)
SAFETY_ENABLED=false

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_GENERATED=dev-ai-images-generated
AWS_BUCKET_UPLOADS=dev-ai-images-uploads

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
