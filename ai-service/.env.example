# AI Service (FastAPI Python) — Environment Variables
# Copy to .env and fill in real values

PORT=8000
SERVICE_NAME=ai-service

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Stability AI API key — https://platform.stability.ai
STABILITY_API_KEY=<your-stability-ai-api-key>

# OpenAI API key (DALL-E 3 fallback) — https://platform.openai.com
OPENAI_API_KEY=<your-openai-api-key>

# HuggingFace API key (secondary fallback) — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=<your-huggingface-api-key>

# ─── Safety Middleware ────────────────────────────────────────────────────────
# Set to true when ai.safety_check.enabled feature flag is ON (Phase 3)
SAFETY_ENABLED=false

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=ap-south-1
AWS_BUCKET_GENERATED=dev-ai-images-generated

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=<your-sentry-dsn>
LOG_LEVEL=info
