# Production Environment Variables — shared across all services
# Real values live in Railway Environment Variables (per service) and Vercel dashboard.
# This file documents the required variables for production deployments.

# ─── Common ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=warn
RAILWAY_ENVIRONMENT=production

# ─── Database (Railway-managed Production) ───────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<railway-prod-host>:5432/aiplatform
REDIS_URL=redis://<railway-prod-host>:6379

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Production uses LaunchDarkly production environment
FEATURE_FLAGS_PROVIDER=launchdarkly
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-prod-server-sdk-key>
VITE_LAUNCHDARKLY_CLIENT_KEY=<your-launchdarkly-prod-client-key>

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY=<your-prod-jwt-private-key>
JWT_PUBLIC_KEY=<your-prod-jwt-public-key>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
GOOGLE_CLIENT_ID=<your-prod-google-client-id>
GOOGLE_CLIENT_SECRET=<your-prod-google-client-secret>
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/google/callback

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=us-east-1
AWS_BUCKET_GENERATED=prod-ai-images-generated
AWS_BUCKET_UPLOADS=prod-ai-images-uploads
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
CLOUDFRONT_DOMAIN=https://cdn.yourdomain.com

# ─── AI Providers ────────────────────────────────────────────────────────────
STABILITY_API_KEY=<your-stability-ai-api-key>
OPENAI_API_KEY=<your-openai-api-key>
HUGGINGFACE_API_KEY=<your-huggingface-api-key>
SAFETY_ENABLED=false

# ─── Service URLs (Railway internal hostnames for Production) ────────────────
AUTH_SERVICE_URL=http://auth-service.railway.internal:3001
USER_SERVICE_URL=http://user-service.railway.internal:3002
IMAGE_SERVICE_URL=http://image-service.railway.internal:3003
NOTIFICATION_SERVICE_URL=http://notification-service.railway.internal:3004
ANALYTICS_SERVICE_URL=http://analytics-service.railway.internal:3005
AI_SERVICE_URL=http://ai-service.railway.internal:8000
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_SENTRY_DSN=<your-prod-sentry-dsn>
VITE_POSTHOG_KEY=<your-posthog-key>
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=<your-prod-sentry-dsn>
