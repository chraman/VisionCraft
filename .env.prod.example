# Production Environment Variables — shared across all services
# Real values live in AWS Secrets Manager + SSM Parameter Store (injected into ECS tasks).
# This file documents the required variables — never commit real values.

# ─── Common ───────────────────────────────────────────────────────────────────
APP_ENV=prod
NODE_ENV=production
LOG_LEVEL=warn

# ─── Database (RDS PostgreSQL 16 Multi-AZ — internal hostname) ────────────────
DATABASE_URL=postgresql://<user>:<password>@<rds-internal-endpoint>:5432/aiplatform

# ─── Redis (ElastiCache — internal hostname) ──────────────────────────────────
REDIS_URL=redis://<elasticache-primary-endpoint>:6379

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_FLAGS_PROVIDER=launchdarkly
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-prod-server-sdk-key>

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY=<your-prod-jwt-private-key>
JWT_PUBLIC_KEY=<your-prod-jwt-public-key>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
GOOGLE_CLIENT_ID=<your-prod-google-client-id>
GOOGLE_CLIENT_SECRET=<your-prod-google-client-secret>
GOOGLE_CALLBACK_URL=https://api.visioncraft.io/api/v1/auth/google/callback

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_BUCKET_GENERATED=prod-ai-images-generated
AWS_BUCKET_UPLOADS=prod-ai-images-uploads
AWS_SES_FROM_EMAIL=noreply@visioncraft.io
CLOUDFRONT_DOMAIN=https://cdn.visioncraft.io

# ─── AI Providers ────────────────────────────────────────────────────────────
STABILITY_API_KEY=<your-stability-ai-api-key>
OPENAI_API_KEY=<your-openai-api-key>
HUGGINGFACE_API_KEY=<your-huggingface-api-key>
SAFETY_ENABLED=false

# ─── Service URLs (ECS Service Connect — private VPC) ────────────────────────
# Internal DNS names registered via ECS Service Connect in the production cluster.
AUTH_SERVICE_URL=http://auth-service.internal:3001
USER_SERVICE_URL=http://user-service.internal:3002
IMAGE_SERVICE_URL=http://image-service.internal:3003
NOTIFICATION_SERVICE_URL=http://notification-service.internal:3004
ANALYTICS_SERVICE_URL=http://analytics-service.internal:3005
AI_SERVICE_URL=http://ai-service.internal:8000

# CORS — production frontend domain(s)
ALLOWED_ORIGINS=https://visioncraft.io,https://www.visioncraft.io

# Public API base URL (ALB or custom domain)
API_BASE_URL=https://api.visioncraft.io

# Public frontend URL
FRONTEND_URL=https://visioncraft.io

# ─── Frontend (Vite — injected at build time, not at container startup) ───────
VITE_APP_ENV=prod
VITE_API_BASE_URL=https://api.visioncraft.io
VITE_SENTRY_DSN=<your-prod-sentry-dsn>
VITE_POSTHOG_KEY=<your-posthog-key>

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=<your-prod-sentry-dsn>
