# Auth Service — Environment Variables
# Copy to .env.local and fill in real values

# ─── Common ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=auth-service
PORT=3001
RAILWAY_ENVIRONMENT=dev

# ─── JWT ──────────────────────────────────────────────────────────────────────
# RS256 asymmetric keys — generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=<RS256-PEM-private-key>
JWT_PUBLIC_KEY=<RS256-PEM-public-key>

# Access token TTL in seconds (default: 900 = 15 minutes)
JWT_ACCESS_TTL=900

# Refresh token TTL in seconds (default: 604800 = 7 days)
JWT_REFRESH_TTL=604800

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose local: postgresql://postgres:postgres@localhost:5432/aiplatform
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiplatform

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_FLAGS_PROVIDER=static
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-sdk-key>
