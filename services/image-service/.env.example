# Image Service — Environment Variables
# Copy to .env.local and fill in real values

# ─── Common ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=image-service
PORT=3003
AWS_ENVIRONMENT=dev

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiplatform

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=us-east-1

# S3 buckets (create these in your AWS account)
AWS_BUCKET_GENERATED=dev-ai-images-generated
AWS_BUCKET_UPLOADS=dev-ai-images-uploads

# CloudFront distribution domain (no trailing slash)
CLOUDFRONT_DOMAIN=https://your-distribution.cloudfront.net

# ─── AI Service ───────────────────────────────────────────────────────────────
# Local dev: http://localhost:8000. ECS QA/prod: http://ai-service.internal:8000 (Service Connect)
AI_SERVICE_URL=http://localhost:8000

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_FLAGS_PROVIDER=static
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-sdk-key>
