# API Gateway — Environment Variables
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=api-gateway
PORT=3000
RAILWAY_ENVIRONMENT=dev

# JWT verification (public key only — private key stays in auth-service)
JWT_PUBLIC_KEY=<RS256-PEM-public-key>

REDIS_URL=redis://localhost:6379

# Internal service URLs (Railway: http://<service>.railway.internal:<port>)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
IMAGE_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
ANALYTICS_SERVICE_URL=http://localhost:3005

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

FEATURE_FLAGS_PROVIDER=static
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-sdk-key>
