# Image Worker — Environment Variables
# Copy to .env.local and fill in real values

# ─── Common ───────────────────────────────────────────────────────────────────
APP_ENV=local
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_NAME=image-worker
PORT=3006

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiplatform

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Downstream services ──────────────────────────────────────────────────────
# Local dev: use localhost. ECS QA/prod: use ECS Service Connect DNS (http://<service>.internal:<port>)
IMAGE_SERVICE_URL=http://localhost:3003
AI_SERVICE_URL=http://localhost:8000

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=us-east-1
AWS_BUCKET_GENERATED=dev-ai-images-generated
AWS_BUCKET_UPLOADS=dev-ai-images-uploads
