# Root .env.example — shared across all services
# Copy to .env.local and fill in real values (never commit real values)

# ─── Common ───────────────────────────────────────────────────────────────────
APP_ENV=local
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Provider: launchdarkly | unleash | static
FEATURE_FLAGS_PROVIDER=static

# LaunchDarkly (qa/prod — server-side SDK key)
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-server-sdk-key>

# LaunchDarkly (frontend client-side key)
VITE_LAUNCHDARKLY_CLIENT_KEY=<your-launchdarkly-client-key>

# Unleash (local dev self-hosted)
UNLEASH_URL=http://localhost:4242/api
UNLEASH_CLIENT_SECRET=<your-unleash-client-secret>
