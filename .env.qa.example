# QA Environment Variables — shared across all services
# Real values live in AWS Secrets Manager + SSM Parameter Store (injected into ECS tasks).
# For local use: copy to .env.qa.local and fill in real values.

# ─── Common ───────────────────────────────────────────────────────────────────
APP_ENV=qa
NODE_ENV=production
LOG_LEVEL=info

# ─── Database (RDS PostgreSQL 16 — internal hostname) ─────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<rds-internal-endpoint>:5432/aiplatform

# ─── Redis (ElastiCache — internal hostname) ──────────────────────────────────
REDIS_URL=redis://<elasticache-primary-endpoint>:6379

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_FLAGS_PROVIDER=launchdarkly
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-qa-server-sdk-key>

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY=<your-qa-jwt-private-key>
JWT_PUBLIC_KEY=<your-qa-jwt-public-key>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
GOOGLE_CLIENT_ID=<your-qa-google-client-id>
GOOGLE_CLIENT_SECRET=<your-qa-google-client-secret>
# Use ALB DNS name (output of: terraform output alb_dns_name)
GOOGLE_CALLBACK_URL=https://<qa-alb-dns>/api/v1/auth/google/callback

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_BUCKET_GENERATED=qa-ai-images-generated
AWS_BUCKET_UPLOADS=qa-ai-images-uploads
AWS_SES_FROM_EMAIL=noreply-qa@visioncraft.io
CLOUDFRONT_DOMAIN=https://<qa-cdn-cloudfront-domain>

# ─── AI Providers ────────────────────────────────────────────────────────────
STABILITY_API_KEY=<your-stability-ai-api-key>
OPENAI_API_KEY=<your-openai-api-key>
HUGGINGFACE_API_KEY=<your-huggingface-api-key>
SAFETY_ENABLED=false

# ─── Service URLs (ECS Service Connect — private VPC) ────────────────────────
# These are the internal DNS names registered via ECS Service Connect.
# Containers resolve these within the visioncraft-qa ECS cluster.
AUTH_SERVICE_URL=http://auth-service.internal:3001
USER_SERVICE_URL=http://user-service.internal:3002
IMAGE_SERVICE_URL=http://image-service.internal:3003
NOTIFICATION_SERVICE_URL=http://notification-service.internal:3004
ANALYTICS_SERVICE_URL=http://analytics-service.internal:3005
AI_SERVICE_URL=http://ai-service.internal:8000

# CORS — set to the CloudFront QA frontend domain
ALLOWED_ORIGINS=https://<qa-cloudfront-domain>

# Public API base URL (ALB DNS — used by getEnvironmentConfig())
API_BASE_URL=https://<qa-alb-dns>

# Public frontend URL (CloudFront domain)
FRONTEND_URL=https://<qa-cloudfront-domain>

# ─── Frontend (Vite — injected at build time, not at container startup) ───────
VITE_APP_ENV=qa
VITE_API_BASE_URL=https://<qa-alb-dns>
VITE_SENTRY_DSN=<your-qa-sentry-dsn>
VITE_POSTHOG_KEY=<your-posthog-key>

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=<your-qa-sentry-dsn>
