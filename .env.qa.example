# QA Environment Variables — shared across all services
# Copy to .env.qa.local and fill in real values (never commit real values)
# Usage: docker compose -f docker-compose.yml -f docker-compose.qa.yml --env-file .env.qa.local up

# ─── Common ───────────────────────────────────────────────────────────────────
NODE_ENV=staging
LOG_LEVEL=info
RAILWAY_ENVIRONMENT=staging

# ─── Database (Railway-managed QA) ───────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<railway-qa-host>:5432/aiplatform
REDIS_URL=redis://<railway-qa-host>:6379

# ─── Feature Flags ────────────────────────────────────────────────────────────
# QA uses LaunchDarkly staging environment
FEATURE_FLAGS_PROVIDER=launchdarkly
LAUNCHDARKLY_SDK_KEY=<your-launchdarkly-qa-server-sdk-key>
VITE_LAUNCHDARKLY_CLIENT_KEY=<your-launchdarkly-qa-client-key>

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY=<your-qa-jwt-private-key>
JWT_PUBLIC_KEY=<your-qa-jwt-public-key>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
GOOGLE_CLIENT_ID=<your-qa-google-client-id>
GOOGLE_CLIENT_SECRET=<your-qa-google-client-secret>
GOOGLE_CALLBACK_URL=https://qa-api.yourdomain.com/api/v1/auth/google/callback

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=us-east-1
AWS_BUCKET_GENERATED=qa-ai-images-generated
AWS_BUCKET_UPLOADS=qa-ai-images-uploads
AWS_SES_FROM_EMAIL=noreply-qa@yourdomain.com
CLOUDFRONT_DOMAIN=https://qa-cdn.yourdomain.com

# ─── AI Providers ────────────────────────────────────────────────────────────
STABILITY_API_KEY=<your-stability-ai-api-key>
OPENAI_API_KEY=<your-openai-api-key>
HUGGINGFACE_API_KEY=<your-huggingface-api-key>
SAFETY_ENABLED=false

# ─── Service URLs (Railway internal hostnames for QA project) ────────────────
AUTH_SERVICE_URL=http://auth-service-qa.railway.internal:3001
USER_SERVICE_URL=http://user-service-qa.railway.internal:3002
IMAGE_SERVICE_URL=http://image-service-qa.railway.internal:3003
NOTIFICATION_SERVICE_URL=http://notification-service-qa.railway.internal:3004
ANALYTICS_SERVICE_URL=http://analytics-service-qa.railway.internal:3005
AI_SERVICE_URL=http://ai-service-qa.railway.internal:8000
ALLOWED_ORIGINS=https://qa.yourdomain.com

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://qa-api.yourdomain.com
VITE_SENTRY_DSN=<your-qa-sentry-dsn>
VITE_POSTHOG_KEY=<your-posthog-key>
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=<your-qa-sentry-dsn>
