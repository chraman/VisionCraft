{
  "name": "ai-image-platform",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "generate:api-client": "turbo run generate:api-client",
    "prepare": "husky",
    "dev:web": "turbo dev --filter=@ai-platform/web",
    "dev:api-gateway": "turbo dev --filter=@ai-platform/api-gateway",
    "dev:auth": "turbo dev --filter=@ai-platform/auth-service",
    "dev:user": "turbo dev --filter=@ai-platform/user-service",
    "dev:image": "turbo dev --filter=@ai-platform/image-service",
    "dev:notify": "turbo dev --filter=@ai-platform/notification-service",
    "dev:analytics": "turbo dev --filter=@ai-platform/analytics-service",
    "dev:backend": "turbo dev --filter=@ai-platform/api-gateway --filter=@ai-platform/auth-service --filter=@ai-platform/user-service --filter=@ai-platform/image-service --filter=@ai-platform/notification-service --filter=@ai-platform/analytics-service",
    "start:api-gateway": "turbo start --filter=@ai-platform/api-gateway",
    "start:auth": "turbo start --filter=@ai-platform/auth-service",
    "start:user": "turbo start --filter=@ai-platform/user-service",
    "start:image": "turbo start --filter=@ai-platform/image-service",
    "start:notify": "turbo start --filter=@ai-platform/notification-service",
    "start:analytics": "turbo start --filter=@ai-platform/analytics-service",
    "start:backend": "turbo start --filter=@ai-platform/api-gateway --filter=@ai-platform/auth-service --filter=@ai-platform/user-service --filter=@ai-platform/image-service --filter=@ai-platform/notification-service --filter=@ai-platform/analytics-service",
    "build:qa": "turbo build --filter=@ai-platform/web -- --mode qa",
    "docker:ecr-login": "aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 553138587052.dkr.ecr.ap-south-1.amazonaws.com",
    "docker:build:api-gateway": "docker build -f services/api-gateway/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/api-gateway:latest .",
    "docker:build:auth-service": "docker build -f services/auth-service/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/auth-service:latest .",
    "docker:build:user-service": "docker build -f services/user-service/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/user-service:latest .",
    "docker:build:image-service": "docker build -f services/image-service/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/image-service:latest .",
    "docker:build:notification-service": "docker build -f services/notification-service/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/notification-service:latest .",
    "docker:build:analytics-service": "docker build -f services/analytics-service/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/analytics-service:latest .",
    "docker:build:image-worker": "docker build -f workers/image-worker/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/image-worker:latest .",
    "docker:build:ai-service": "docker build -f ai-service/Dockerfile -t 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/ai-service:latest ai-service/",
    "docker:push:api-gateway": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/api-gateway:latest",
    "docker:push:auth-service": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/auth-service:latest",
    "docker:push:user-service": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/user-service:latest",
    "docker:push:image-service": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/image-service:latest",
    "docker:push:notification-service": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/notification-service:latest",
    "docker:push:analytics-service": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/analytics-service:latest",
    "docker:push:image-worker": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/image-worker:latest",
    "docker:push:ai-service": "docker push 553138587052.dkr.ecr.ap-south-1.amazonaws.com/visioncraft/ai-service:latest",
    "docker:build-push:api-gateway": "pnpm docker:build:api-gateway && pnpm docker:push:api-gateway",
    "docker:build-push:auth-service": "pnpm docker:build:auth-service && pnpm docker:push:auth-service",
    "docker:build-push:user-service": "pnpm docker:build:user-service && pnpm docker:push:user-service",
    "docker:build-push:image-service": "pnpm docker:build:image-service && pnpm docker:push:image-service",
    "docker:build-push:notification-service": "pnpm docker:build:notification-service && pnpm docker:push:notification-service",
    "docker:build-push:analytics-service": "pnpm docker:build:analytics-service && pnpm docker:push:analytics-service",
    "docker:build-push:image-worker": "pnpm docker:build:image-worker && pnpm docker:push:image-worker",
    "docker:build-push:ai-service": "pnpm docker:build:ai-service && pnpm docker:push:ai-service",
    "ecs:deploy:api-gateway": "aws ecs update-service --cluster visioncraft-qa --service api-gateway --force-new-deployment --region ap-south-1",
    "ecs:deploy:auth-service": "aws ecs update-service --cluster visioncraft-qa --service auth-service --force-new-deployment --region ap-south-1",
    "ecs:deploy:user-service": "aws ecs update-service --cluster visioncraft-qa --service user-service --force-new-deployment --region ap-south-1",
    "ecs:deploy:image-service": "aws ecs update-service --cluster visioncraft-qa --service image-service --force-new-deployment --region ap-south-1",
    "ecs:deploy:notification-service": "aws ecs update-service --cluster visioncraft-qa --service notification-service --force-new-deployment --region ap-south-1",
    "ecs:deploy:analytics-service": "aws ecs update-service --cluster visioncraft-qa --service analytics-service --force-new-deployment --region ap-south-1",
    "ecs:deploy:image-worker": "aws ecs update-service --cluster visioncraft-qa --service image-worker --force-new-deployment --region ap-south-1",
    "ecs:deploy:all": "pnpm ecs:deploy:api-gateway && pnpm ecs:deploy:auth-service && pnpm ecs:deploy:user-service && pnpm ecs:deploy:image-service && pnpm ecs:deploy:notification-service && pnpm ecs:deploy:analytics-service && pnpm ecs:deploy:image-worker",
    "ecs:logs:api-gateway": "aws logs tail /ecs/visioncraft-qa/api-gateway --follow --region ap-south-1",
    "ecs:logs:auth-service": "aws logs tail /ecs/visioncraft-qa/auth-service --follow --region ap-south-1",
    "ecs:logs:user-service": "aws logs tail /ecs/visioncraft-qa/user-service --follow --region ap-south-1",
    "ecs:logs:image-service": "aws logs tail /ecs/visioncraft-qa/image-service --follow --region ap-south-1",
    "ecs:logs:notification-service": "aws logs tail /ecs/visioncraft-qa/notification-service --follow --region ap-south-1",
    "ecs:logs:analytics-service": "aws logs tail /ecs/visioncraft-qa/analytics-service --follow --region ap-south-1",
    "ecs:logs:image-worker": "aws logs tail /ecs/visioncraft-qa/image-worker --follow --region ap-south-1",
    "ecs:status": "aws ecs describe-services --cluster visioncraft-qa --services api-gateway auth-service user-service image-service notification-service analytics-service image-worker --region ap-south-1 --query \"services[*].{name:serviceName,running:runningCount,desired:desiredCount,status:status}\" --output table",
    "db:migrate:qa": "aws ecs run-task --cluster visioncraft-qa --task-definition visioncraft-qa-auth-service --launch-type FARGATE --region ap-south-1 --network-configuration \"awsvpcConfiguration={subnets=[$ECS_PRIVATE_SUBNET],securityGroups=[$ECS_APP_SG],assignPublicIp=DISABLED}\" --overrides file://infra/scripts/migrate-qa-override.json",
    "web:build:qa": "turbo build:qa --filter=@ai-platform/web",
    "web:sync:qa": "aws s3 sync apps/web/dist/ s3://visioncraft-frontend-qa/ --delete --exclude index.html --cache-control \"public,max-age=31536000,immutable\" && aws s3 cp apps/web/dist/index.html s3://visioncraft-frontend-qa/index.html --cache-control \"no-cache,no-store,must-revalidate\"",
    "web:invalidate:qa": "aws cloudfront create-invalidation --distribution-id EE1F23WMN7QUN --paths \"/*\" --region ap-south-1",
    "web:deploy:qa": "pnpm web:build:qa && pnpm web:sync:qa && pnpm web:invalidate:qa"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "core-js",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
